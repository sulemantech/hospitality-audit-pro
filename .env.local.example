# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: supabase.com > project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to client

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: resend.com > API Keys
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Phase 2 AI (add when ready — not needed for MVP) ────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
